{
  "name": "analyticsmap",
  "version": "0.1.0",
  "type": "module",
  "description": "Analytics coverage tool for mobile and web apps. Detects providers, maps features, shows what's tracked and what's missing.",
  "license": "MIT",
  "author": "Tiago Flores",
  "repository": {
    "type": "git",
    "url": "https://github.com/TiagoMJFlores/AnalyticsMap"
  },
  "keywords": [
    "analytics",
    "tracking",
    "coverage",
    "firebase",
    "sentry",
    "posthog",
    "mixpanel",
    "amplitude",
    "react-native",
    "swift",
    "kotlin",
    "flutter"
  ],
  "bin": {
    "analyticsmap": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@analyticsmap/shared": "workspace:^",
    "@anthropic-ai/sdk": "^0.80.0",
    "commander": "^13.0.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.4.0",
    "ora": "^8.2.0",
    "express": "^5.1.0",
    "cors": "^2.8.5",
    "open": "^10.1.0",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
